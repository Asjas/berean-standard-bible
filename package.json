{
  "name": "berean-standard-bible",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Berean Standard Bible reading app built with Tauri, React, and TypeScript",
  "author": "A-J Roos <asjasroos@proton.me>",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite --port 4173",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --cache-location .cache/eslint --cache-strategy content .",
    "format": "prettier --write --cache --cache-location .cache/prettier \"**/*.+(ts|tsx|css|html|json|md)\"",
    "check-format": "prettier --list-different --cache --cache-location .cache/prettier \"**/*.+(ts|tsx|css|html|json|md)\""
  },
  "dependencies": {
    "@orama/orama": "3.1.18",
    "@tanstack/react-router": "1.163.3",
    "browserslist": "4.28.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.4.0",
    "usfm-js": "3.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/eslintrc": "3.3.4",
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/eslint-plugin-router": "1.161.4",
    "@tanstack/router-plugin": "1.164.0",
    "@tauri-apps/cli": "2.10.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@xeonlink/prettier-plugin-organize-attributes": "1.1.0",
    "eslint": "9.39.2",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-es-x": "9.3.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-unused-imports": "4.3.0",
    "globals": "17.3.0",
    "lightningcss": "1.30.2",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.1"
  }
}
