{
  "name": "berean-standard-bible",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Berean Standard Bible reading app built with Tauri, React, and TypeScript",
  "author": "A-J Roos <asjasroos@proton.me>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite --port 4173",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --cache-location .cache/eslint --cache-strategy content .",
    "format": "prettier --write --cache --cache-location .cache/prettier \"**/*.+(ts|tsx|css|html|json|md)\"",
    "check-format": "prettier --list-different --cache --cache-location .cache/prettier \"**/*.+(ts|tsx|css|html|json|md)\""
  },
  "dependencies": {
    "@orama/orama": "3.1.18",
    "@tanstack/react-router": "1.168.23",
    "browserslist": "4.28.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "usfm-js": "3.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/eslint-plugin-router": "1.161.6",
    "@tanstack/router-plugin": "1.167.22",
    "@tauri-apps/cli": "2.10.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@xeonlink/prettier-plugin-organize-attributes": "1.1.0",
    "eslint": "10.2.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-es-x": "9.6.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.5.0",
    "lightningcss": "1.32.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.9"
  }
}
